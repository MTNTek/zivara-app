{
  "name": "@zivara/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --config test/jest-e2e.json --passWithNoTests",
    "lint": "tsc --noEmit && echo Lint passed",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:migrate": "ts-node -r tsconfig-paths/register src/database/migrate.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "db:verify": "ts-node -r tsconfig-paths/register src/database/verify.ts"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/schedule": "4.1.1",
    "@nestjs/throttler": "^6.2.1",
    "@zivara/shared": "*",
    "bcrypt": "5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "16.4.5",
    "drizzle-orm": "0.30.10",
    "nodemailer": "^6.9.13",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "postgres": "3.4.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "10.4.15",
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "20.17.19",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "drizzle-kit": "^0.21.4",
    "jest": "29.7.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/../tsconfig.test.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────

# PostgreSQL connection string used by the NestJS API and Drizzle ORM
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zivara

# PostgreSQL service configuration (used by docker-compose)
POSTGRES_DB=zivara
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ─────────────────────────────────────────────
# Authentication — JWT
# ─────────────────────────────────────────────

# Secret key used to sign short-lived JWT access tokens (use a long random string)
JWT_ACCESS_SECRET=

# Secret key used to sign long-lived JWT refresh tokens (use a different long random string)
JWT_REFRESH_SECRET=

# How long access tokens are valid (e.g. 15m)
JWT_ACCESS_EXPIRY=

# How long refresh tokens are valid (e.g. 30d)
JWT_REFRESH_EXPIRY=

# ─────────────────────────────────────────────
# Email — SMTP
# ─────────────────────────────────────────────

# Hostname of the SMTP server (e.g. smtp.mailgun.org or smtp.sendgrid.net)
SMTP_HOST=

# SMTP port (typically 587 for STARTTLS or 465 for SSL)
SMTP_PORT=

# SMTP username / login for the email provider account
SMTP_USER=

# SMTP password / API key for the email provider account
SMTP_PASS=

# ─────────────────────────────────────────────
# File Storage — AWS S3
# ─────────────────────────────────────────────

# Name of the private S3 bucket used to store uploaded documents and images
AWS_S3_BUCKET=

# AWS region where the S3 bucket and other AWS services are deployed (e.g. me-south-1)
AWS_REGION=

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────

# Runtime environment — must be one of: development, test, production
NODE_ENV=

# Port the NestJS API server listens on (default: 4000)
API_PORT=

# Port the Next.js web app listens on (default: 3000)
WEB_PORT=

# Public URL of the API, used by the Next.js frontend to make API calls
# In local dev this is typically http://localhost:4000
NEXT_PUBLIC_API_URL=

# ─────────────────────────────────────────────
# Authentication — Email & Frontend
# ─────────────────────────────────────────────

# Base URL of the frontend app — used in verification and password reset email links
FRONTEND_URL=http://localhost:3000

# Email "from" address for transactional emails
SMTP_FROM=noreply@zivara.com

# Set to 'true' in development to skip sending verification emails.
# Registration will auto-verify accounts without requiring email confirmation.
# JWT, RBAC, password hashing, account lockout, and rate limiting remain fully active.
SKIP_EMAIL_VERIFICATION=true

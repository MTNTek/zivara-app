# ─────────────────────────────────────────────────────────────────────────────
# Zivara — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# NEVER commit .env to version control.
#
# Production: All values come from AWS Secrets Manager injected into ECS tasks.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zivara

# PostgreSQL service config (used by docker-compose postgres service)
POSTGRES_DB=zivara
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ─── Authentication — JWT ──────────────────────────────────────────────────────
#
# SECURITY: Use long random hex strings in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_ACCESS_SECRET=replace-with-64-char-random-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Email — SMTP ─────────────────────────────────────────────────────────────

# Production: use AWS SES (smtp.us-east-1.amazonaws.com, port 587)
# Local dev: can use MailHog or leave empty when SKIP_EMAIL_VERIFICATION=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASS=dev
SMTP_FROM=noreply@zivara.com

# ─── File Storage — AWS S3 ────────────────────────────────────────────────────

# Private bucket — documents and profile photos accessed via presigned URLs
AWS_S3_BUCKET=zivara-documents-prod
AWS_REGION=me-south-1

# ─── Application ──────────────────────────────────────────────────────────────

# Runtime environment: development | test | production
NODE_ENV=development

# API server port
API_PORT=4000

# Web server port
WEB_PORT=3000

# Public API URL — used by the Next.js frontend
# Local: http://localhost:4000
# Production: https://api.zivara.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Frontend base URL — used in email links
FRONTEND_URL=http://localhost:3000

# ─── Development Auth ─────────────────────────────────────────────────────────
#
# Set to 'true' to skip email verification during development.
# Registration auto-verifies accounts — no email required.
# JWT, RBAC, password hashing, account lockout, and rate limiting remain active.
# MUST be 'false' or unset in production.
SKIP_EMAIL_VERIFICATION=true

# ─── GitHub Actions Secrets (do NOT add to .env — set in repo Settings) ───────
#
# AWS_ACCESS_KEY_ID         — AWS IAM key for ECR push and ECS deploy
# AWS_SECRET_ACCESS_KEY     — AWS IAM secret
# AWS_ECR_REGISTRY          — ECR registry URL (e.g. 123456789.dkr.ecr.me-south-1.amazonaws.com)
# ECS_SUBNET                — Private subnet ID for migration task
# ECS_SECURITY_GROUP        — Security group for migration task
# APP_URL                   — Production URL for smoke test (e.g. https://api.zivara.com)
